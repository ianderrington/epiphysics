# Chat Configuration
# Set to 'true' to use real Claude AI (requires ANTHROPIC_API_KEY)
# Leave unset or set to 'false' to use mock responses (no API costs)
NEXT_PUBLIC_USE_REAL_AI=false

# Anthropic API Key (only needed if NEXT_PUBLIC_USE_REAL_AI=true)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

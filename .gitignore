# ==============================================================================
# Supernal Coding - Required Ignores
# ==============================================================================
#
# Directory structure:
#   .supernal/        → TRACKED (team config, checked into git)
#   .supernal-local/  → IGNORED (runtime data, caches, CLI state)
#   .worktrees/       → IGNORED (git worktrees for multi-agent dev)
#
# ==============================================================================

# Supernal local runtime (caches, logs, CLI state)
.supernal-local/
.openclaw/
messages/
misc/
**/__pycache__/
AGENTS.bespoke.md
HEARTBEAT.md
SOUL.md
TOOLS.md
USER.md

# Git worktrees (multi-agent development)
.worktrees/

# Dynamic cursor rules (generated by monitor daemon)
.cursor/rules/AGENT-STATE.mdc

# Credential files (never commit)
*.credentials.json
*.credentials.enc

# Citation verification downloads (not committed)
papers/
*.pdf
docs/theory/refs/
# arXiv generated output (source-of-truth is the .md files)
arxiv/

# Image generation variants (-2, -3 etc — only keep -1 canonical)
docs/**/images/*-[2-9].png
docs/**/images/*-1[0-9].png
public/docs/**/images/*-[2-9].png
public/docs/**/images/*-1[0-9].png
public/docs/**/images/cover-*.png
